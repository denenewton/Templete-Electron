# instalar dependências (usa pnpm no repo)
pnpm install

# gerar o client (o script postinstall já roda isso, mas pode rodar manualmente)
pnpm prisma generate

# aplicar migrations em dev (cria prisma/dev.db)
pnpm prisma migrate dev --name init

# alternativa sem migrations (aplica schema direto)
pnpm prisma db push

# abrir Prisma Studio (UI)
pnpm prisma studio

# iniciar a aplicação
pnpm dev

